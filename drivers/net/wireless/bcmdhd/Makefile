	DHDCFLAGS += -DDHDTCPACK_SUPPRESS
	DHDCFLAGS += -DTSQ_MULTIPLIER=10
# Keep alive
	DHDCFLAGS += -DKEEP_ALIVE -DCUSTOM_KEEP_ALIVE_SETTING=30000
# Packet filter
	DHDCFLAGS += -DPKT_FILTER_SUPPORT -DBLOCK_IPV6_PACKET
	DHDCFLAGS += -DPKTPRIO_OVERRIDE
# ARP
	DHDCFLAGS += -DARP_OFFLOAD_SUPPORT
# Wakeup
	DHDCFLAGS += -DDHD_PACKET_TIMEOUT_MS=50 -DMAX_TX_TIMEOUT=50
	DHDCFLAGS += -DCUSTOM_EVENT_PM_WAKE=20
# Misc feature
	DHDCFLAGS += -DCUSTOM_LONG_RETRY_LIMIT=12
	DHDCFLAGS += -DIOCTL_RESP_TIMEOUT=5000
endif

