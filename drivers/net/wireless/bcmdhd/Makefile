	DHDCFLAGS += -DENABLE_INSMOD_NO_FW_LOAD
	DHDCFLAGS += -DPOWERUP_MAX_RETRY=1 -DWIFI_TURNOFF_DELAY=10
	DHDCFLAGS += -DMULTIPLE_SUPPLICANT -DIFACE_HANG_FORCE_DEV_CLOSE
